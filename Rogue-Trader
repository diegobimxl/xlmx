<script src="https://cdnjs.cloudflare.com/ajax/libs/socket.io/4.7.4/socket.io.min.js"></script>
<script>
let socket=null,playerId=null,playerState=null,marketData=null,lifestyleShop={},businessShop={},currentTab='portfolio',selectedCell=null,currentTradeTicker=null,currentTradeType='stock',currentBetEvent=null,currentBMItem=null;
const SERVER_URL=location.origin;function joinGame(){
  const username=document.getElementById('usernameInput').value.trim()||'Anon_'+Math.floor(Math.random()*9999);
  let savedId=null;try{savedId=sessionStorage.getItem('rogue_trader_id')}catch(e){}
  socket=io(SERVER_URL,{transports:['websocket','polling']});
  socket.on('connect',()=>{socket.emit('join',{username,player_id:savedId})});
  socket.on('joined',(data)=>{
    playerId=data.player_id;playerState=data.player;marketData=data.market;lifestyleShop=data.lifestyle_shop||{};businessShop=data.business_shop||{};
    try{sessionStorage.setItem('rogue_trader_id',playerId)}catch(e){}
    document.getElementById('loginScreen').classList.add('hidden');document.getElementById('app').style.display='flex';
    renderCurrentTab();updateStatusBar();updateNewsTicker();
  });
  socket.on('market_update',(data)=>{
    marketData=data;
    if(playerState){const me=data.leaderboard.find(p=>p.username===playerState.username);if(me)playerState.net_worth=me.net_worth}
    renderCurrentTab();updateStatusBar();updateNewsTicker();updatePlayersCount();
  });
  socket.on('trade_result',(data)=>{
    if(data.success){playerState=data.player;showToast('Trade executed','success');closeModal('tradeModal');closeModal('bmModal');renderCurrentTab();updateStatusBar()}
    else{if(data.busted){playerState=data.player;showBusted()}showToast(data.error,'error')}
  });
  socket.on('state_update',(data)=>{playerState=data.player;marketData=data.market;renderCurrentTab();updateStatusBar()});
}
function switchTab(tab){currentTab=tab;document.querySelectorAll('.ribbon-tab,.sheet-tab').forEach(el=>{el.classList.toggle('active',el.dataset.tab===tab)});renderCurrentTab()}
function renderCurrentTab(){
  if(!marketData||!playerState)return;const grid=document.getElementById('gridContainer');
  switch(currentTab){case 'portfolio':grid.innerHTML=renderPortfolio();break;case 'stocks':grid.innerHTML=renderMarket('stocks');break;case 'crypto':grid.innerHTML=renderMarket('crypto');break;case 'forex':grid.innerHTML=renderMarket('forex');break;case 'sports':grid.innerHTML=renderSports();break;case 'blackmarket':grid.innerHTML=renderBlackMarket();break;case 'lifestyle':grid.innerHTML=renderLifestyle();break;case 'business':grid.innerHTML=renderBusiness();break;case 'leaderboard':grid.innerHTML=renderLeaderboard();break;case 'news':grid.innerHTML=renderNews();break}
}function $(val){return typeof val==='number'?(val>=0?'$'+val.toLocaleString('en-US',{minimumFractionDigits:2,maximumFractionDigits:2}):'-$'+Math.abs(val).toLocaleString('en-US',{minimumFractionDigits:2,maximumFractionDigits:2})):val}
function pct(val){return(val>=0?'+':'')+val.toFixed(2)+'%'}
function cls(val){return val>0?'pos':val<0?'neg':''}
function makeRow(rowNum,cells){let html='<div class="grid-row"><div class="row-num">'+rowNum+'</div>';cells.forEach(c=>{const classes=['grid-cell'];if(c.num)classes.push('num');if(c.cls)classes.push(c.cls);if(c.header)classes.push('header-cell');const onclick=c.onclick?' onclick="'+c.onclick+'"':'';html+='<div class="'+classes.join(' ')+'"'+onclick+'>'+(c.v||'')+'</div>'});html+='</div>';return html}
function makeHeaders(cols){let html='<div class="col-headers"><div class="row-num"></div>';const letters='ABCDEFGHIJKLMNOP';cols.forEach((c,i)=>{html+='<div class="col-header">'+(letters[i]||'')+'</div>'});html+='</div>';return html}
function sparklineSVG(history,color){if(!history||history.length<2)return'';const min=Math.min(...history),max=Math.max(...history),range=max-min||1,w=50,h=14;const points=history.map((v,i)=>{const x=(i/(history.length-1))*w,y=h-((v-min)/range)*h;return x+','+y}).join(' ');return'<span class="sparkline"><svg viewBox="0 0 '+w+' '+h+'" preserveAspectRatio="none"><polyline points="'+points+'" fill="none" stroke="'+(color||'#4472C4')+'" stroke-width="1.2"/></svg></span>'}
function formatPrice(p){if(p>=1000)return'$'+p.toLocaleString('en-US',{minimumFractionDigits:2,maximumFractionDigits:2});if(p>=1)return'$'+p.toFixed(2);if(p>=0.01)return'$'+p.toFixed(4);return'$'+p.toFixed(8)}
function renderPortfolio(){
  const p=playerState;let html=makeHeaders(['','B','C','D','E']);let row=1;
  html+=makeRow(row++,[{v:'ACCOUNT SUMMARY',header:true},{v:''},{v:''},{v:''},{v:''}]);
  html+=makeRow(row++,[{v:'Cash Balance'},{v:$(p.cash),num:true,cls:p.cash>10000?'pos':p.cash<1000?'neg':''},{v:''},{v:'Net Worth'},{v:$(p.net_worth),num:true,cls:'pos'}]);
  html+=makeRow(row++,[{v:'Monthly Expenses'},{v:$(p.monthly_expenses),num:true,cls:'neg'},{v:''},{v:'Monthly Income'},{v:$(p.monthly_income),num:true,cls:'pos'}]);
  html+=makeRow(row++,[{v:'Total Trades'},{v:p.total_trades,num:true},{v:''},{v:'Total P&L'},{v:$(p.total_profit),num:true,cls:cls(p.total_profit)}]);
  html+=makeRow(row++,[{v:''},{v:''},{v:''},{v:''},{v:''}]);
  html+=makeRow(row++,[{v:'NET WORTH TREND',header:true},{v:sparklineSVG(p.net_worth_history,p.net_worth_history[p.net_worth_history.length-1]>=p.net_worth_history[0]?'#107c10':'#c00')},{v:''},{v:''},{v:''}]);
  html+=makeRow(row++,[{v:''},{v:''},{v:''},{v:''},{v:''}]);
  html+=makeRow(row++,[{v:'HOLDINGS',header:true},{v:'Qty',header:true},{v:'Avg Cost',header:true},{v:'Mkt Price',header:true},{v:'P&L',header:true}]);  const portfolio=p.portfolio||{};const tickers=Object.keys(portfolio);
  if(tickers.length===0)html+=makeRow(row++,[{v:'No positions yet'},{v:''},{v:''},{v:''},{v:''}]);
