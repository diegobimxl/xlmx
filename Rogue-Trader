def tick_prices():
    with game.lock:
        for ticker, data in game.market_prices.items():
            old_price = data["price"]
            data["prev_price"] = old_price
            if data["type"] == "stock": base_vol = 0.02
            elif data["type"] == "crypto": base_vol = 0.04
            else: base_vol = 0.01
            vol = base_vol * (VOLATILITY_MULTIPLIER / 50)
            change = random.gauss(0, vol)
            if random.random() < 0.05:
                change *= random.uniform(3, 8)
            new_price = max(0.001, old_price * (1 + change))
            data["price"] = round(new_price, 6)            data["history"].append(round(new_price, 6))
            if len(data["history"]) > 60: data["history"] = data["history"][-60:]
            data["high_24h"] = max(data["high_24h"], new_price)
            data["low_24h"] = min(data["low_24h"], new_price)
        for item_id, data in game.black_market.items():
            vol = data["volatility"] * (VOLATILITY_MULTIPLIER / 80)
            change = random.gauss(0, vol)
            if random.random() < 0.08: change *= random.uniform(2, 5)
            new_price = max(data["base_price"] * 0.1, data["price"] * (1 + change))
            data["price"] = round(new_price, 2)
            if random.random() < 0.1: data["available"] = random.randint(1, 5)
            data["heat"] = max(0, data["heat"] - 0.01)
        for event in game.sports_events:
            if event["status"] == "upcoming":
                event["starts_in"] -= 1
                if event["starts_in"] <= 0: event["status"] = "live"
            elif event["status"] == "live":
                if random.random() < 0.15:
                    r = random.random()
                    if event["draw_odds"] and r < 0.25: event["result"] = "draw"
                    elif r < 0.55: event["result"] = "home"
                    else: event["result"] = "away"
                    event["status"] = "finished"
                    settle_bets(event)
        active_events = [e for e in game.sports_events if e["status"] != "finished"]
        if len(active_events) < 4: game._generate_sports_events()
        if random.random() < 0.3: generate_random_news()        for pid, player in game.players.items():
            player.calculate_net_worth(game.market_prices, game.black_market)
        now = time.time()
        if now - game.last_expense_tick >= 60:
            fraction = 60 / DAY_DURATION
            for pid, player in game.players.items():
                player.recalc_expenses()
                daily_net = (player.monthly_income - player.monthly_expenses) / 30
                player.cash += daily_net * fraction
                if player.cash < 0: player.cash = 0
                if player.busted:
                    player.bust_timer -= 1
                    if player.bust_timer <= 0: player.busted = False
            game.last_expense_tick = now
        if now - game.last_daily_tick >= DAY_DURATION:
            game.game_day += 1
            game.last_daily_tick = now
            for ticker, data in game.market_prices.items():
                data["high_24h"] = data["price"]
                data["low_24h"] = data["price"]

def settle_bets(event):
    for pid, player in game.players.items():
        remaining_bets = []
        for bet in player.bets:
            if bet["event_id"] == event["id"]:
                if bet["pick"] == event["result"]:
                    winnings = bet["amount"] * bet["odds"]
                    player.cash += winnings
                    player.total_profit += winnings - bet["amount"]                    game._generate_news(f"{player.username} wins ${winnings:,.0f} bet on {event['home']} vs {event['away']}!", "bullish")
                else:
                    player.total_profit -= bet["amount"]
            else:
                remaining_bets.append(bet)
        player.bets = remaining_bets

def game_loop():
    while True:
        tick_prices()
        market_data = get_market_snapshot()
        socketio.emit('market_update', market_data, namespace='/')
        time.sleep(TICK_INTERVAL)

def get_market_snapshot():
    stocks, crypto, forex = {}, {}, {}
    for ticker, data in game.market_prices.items():
        entry = {"name": data["name"], "price": data["price"], "prev_price": data["prev_price"], "change_pct": round(((data["price"] - data["prev_price"]) / data["prev_price"]) * 100, 2) if data["prev_price"] else 0, "high": data["high_24h"], "low": data["low_24h"], "history": data["history"][-30:]}
        if data["type"] == "stock":
            entry["sector"] = data.get("sector", "")
            stocks[ticker] = entry
        elif data["type"] == "crypto": crypto[ticker] = entry
        elif data["type"] == "forex": forex[ticker] = entry
    return {"stocks": stocks, "crypto": crypto, "forex": forex, "black_market": {k: {"name": v["name"], "price": v["price"], "available": v["available"], "heat": round(v["heat"], 2)} for k, v in game.black_market.items()}, "sports": [e for e in game.sports_events if e["status"] != "finished"][:12], "news": game.news_feed[:15], "leaderboard": get_leaderboard(), "game_day": game.game_day, "timestamp": time.time()}

