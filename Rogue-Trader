@media(max-width:600px){.grid-cell{min-width:65px;max-width:100px;font-size:9px;padding:2px 3px}.col-header{min-width:65px;max-width:100px;font-size:8px}.row-num{width:22px;min-width:22px;font-size:8px}}
</style>
