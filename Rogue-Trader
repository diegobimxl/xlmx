@socketio.on('trade')
def handle_trade(data):
    player_id = data.get('player_id')
    ticker = data.get('ticker')
    action = data.get('action')
    qty = data.get('qty', 0)    with game.lock:
        player = game.players.get(player_id)
        if not player or player.busted:
            emit('trade_result', {'success': False, 'error': 'Cannot trade right now.'}); return
        market = game.market_prices.get(ticker)
        if not market:
            emit('trade_result', {'success': False, 'error': 'Invalid ticker.'}); return
        price = market["price"]
        if action == "buy":
            cost = price * qty
            if cost > player.cash:
                emit('trade_result', {'success': False, 'error': 'Not enough cash.'}); return
            player.cash -= cost
            if ticker in player.portfolio:
                old = player.portfolio[ticker]
                total_qty = old["qty"] + qty
                old["avg_cost"] = ((old["avg_cost"] * old["qty"]) + cost) / total_qty
                old["qty"] = total_qty
            else:
                player.portfolio[ticker] = {"qty": qty, "avg_cost": price}
            player.total_trades += 1
        elif action == "sell":
            if ticker not in player.portfolio or player.portfolio[ticker]["qty"] < qty:
                emit('trade_result', {'success': False, 'error': 'Not enough shares.'}); return
            revenue = price * qty
            player.cash += revenue
            profit = (price - player.portfolio[ticker]["avg_cost"]) * qty
            player.total_profit += profit            player.portfolio[ticker]["qty"] -= qty
            if player.portfolio[ticker]["qty"] <= 0: del player.portfolio[ticker]
            player.total_trades += 1
        player.calculate_net_worth(game.market_prices, game.black_market)
    emit('trade_result', {'success': True, 'player': player.to_dict()})

