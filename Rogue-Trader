class PlayerState:
    def __init__(self, player_id, username):
        self.id = player_id
        self.username = username
        self.cash = STARTING_CASH
        self.portfolio = {}
        self.black_market_inv = {}
        self.bets = []
        self.lifestyle = []
        self.businesses = []
        self.monthly_expenses = MONTHLY_EXPENSES_BASE
        self.monthly_income = 0
        self.net_worth = STARTING_CASH
        self.net_worth_history = [STARTING_CASH]
        self.total_trades = 0
        self.total_profit = 0
        self.joined_at = time.time()
        self.last_active = time.time()
        self.busted = False
        self.bust_timer = 0
        self.achievements = []
        self.day_started = 1

    def calculate_net_worth(self, market_prices, black_market):
        total = self.cash
        for ticker, pos in self.portfolio.items():
            if ticker in market_prices:
                total += pos["qty"] * market_prices[ticker]["price"]        for item_id, pos in self.black_market_inv.items():
            if item_id in black_market:
                total += pos["qty"] * black_market[item_id]["price"]
        for biz_id in self.businesses:
            if biz_id in BUSINESSES:
                total += BUSINESSES[biz_id]["cost"] * 0.7
        self.net_worth = round(total, 2)
        self.net_worth_history.append(self.net_worth)
        if len(self.net_worth_history) > 100:
            self.net_worth_history = self.net_worth_history[-100:]
        return self.net_worth

    def recalc_expenses(self):
        self.monthly_expenses = MONTHLY_EXPENSES_BASE
        self.monthly_income = 0
        categories_reduced = set()
        for item_key in self.lifestyle:
            item = LIFESTYLE_ITEMS.get(item_key, {})
            cat = item.get("category", "")
            if cat not in categories_reduced:
                self.monthly_expenses -= item.get("expense_reduction", 0)
                categories_reduced.add(cat)
            self.monthly_expenses += item.get("expense_add", 0)
        for biz_id in self.businesses:
            biz = BUSINESSES.get(biz_id, {})
            base_income = biz.get("monthly_income", 0)
            vol = biz.get("volatility", 0.2)
            actual = base_income * (1 + random.uniform(-vol, vol))            self.monthly_income += max(0, actual)
        self.monthly_expenses = max(0, self.monthly_expenses)

    def to_dict(self):
        return {"id": self.id, "username": self.username, "cash": round(self.cash, 2), "net_worth": round(self.net_worth, 2), "net_worth_history": self.net_worth_history[-30:], "portfolio": self.portfolio, "black_market_inv": self.black_market_inv, "bets": self.bets, "lifestyle": self.lifestyle, "businesses": self.businesses, "monthly_expenses": round(self.monthly_expenses, 2), "monthly_income": round(self.monthly_income, 2), "total_trades": self.total_trades, "total_profit": round(self.total_profit, 2), "busted": self.busted, "bust_timer": self.bust_timer, "achievements": self.achievements}

