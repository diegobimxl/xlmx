.login-input{width:260px;padding:10px 14px;border:1px solid rgba(255,255,255,.3);background:rgba(255,255,255,.1);border-radius:3px;color:white;font-size:13px;text-align:center;margin-bottom:12px}
.login-input::placeholder{color:rgba(255,255,255,.5)}
.login-btn{padding:10px 40px;background:white;color:#217346;border:none;border-radius:3px;font-weight:700;font-size:12px;cursor:pointer;letter-spacing:.5px}
.login-btn:active{opacity:.8}
.login-disclaimer{font-size:8px;opacity:.4;margin-top:16px;text-align:center;max-width:260px;line-height:1.4}
.trade-controls{display:flex;gap:4px;align-items:center;margin-top:6px}
.trade-controls input{width:60px;text-align:center}
.qty-btn{width:26px;height:26px;display:flex;align-items:center;justify-content:center;border:1px solid #ccc;background:#f5f5f5;cursor:pointer;font-weight:700;font-size:14px;border-radius:2px}
.toast{position:fixed;top:32px;left:50%;transform:translateX(-50%);background:#333;color:white;padding:8px 16px;border-radius:3px;font-size:11px;z-index:300;display:none;max-width:90vw;text-align:center}
.toast.show{display:block;animation:fadeInOut 3s forwards}
@keyframes fadeInOut{0%{opacity:0;transform:translateX(-50%) translateY(-10px)}10%{opacity:1;transform:translateX(-50%) translateY(0)}80%{opacity:1}100%{opacity:0}}
.toast.error{background:var(--red)}.toast.success{background:var(--green)}.toast.warning{background:var(--orange)}
.busted-overlay{position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(220,38,38,.9);z-index:150;display:none;flex-direction:column;align-items:center;justify-content:center;color:white}
