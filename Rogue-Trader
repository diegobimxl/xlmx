        player.recalc_expenses()
        player.calculate_net_worth(game.market_prices, game.black_market)
    emit('trade_result', {'success': True, 'player': player.to_dict()})

@socketio.on('get_state')
def handle_get_state(data):
    player_id = data.get('player_id')
    with game.lock:
        player = game.players.get(player_id)
        if player:
            emit('state_update', {'player': player.to_dict(), 'market': get_market_snapshot()})

